<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Hardware features (optional) -->
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.microphone" android:required="false" />

    <!-- Android XR spatial API (optional — app runs on phone without it) -->
    <uses-feature android:name="android.software.xr.api.spatial" android:required="false" />

    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.CAMERA"/>
    <uses-permission android:name="android.permission.RECORD_AUDIO"/>
    <uses-permission android:name="android.permission.VIBRATE"/>
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <!-- MN.5: re-start the model-free NotificationListenerFgs after a reboot. BootReceiver
         starts the connectedDevice FGS DIRECTLY from BOOT_COMPLETED (exempt from the
         BOOT_COMPLETED FGS-type restrictions) so the device stays a reachable notification
         target without the user re-opening the app. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>
    <uses-permission android:name="android.permission.WAKE_LOCK"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC"/>
    <!-- control_phone: the on-device-model service hosts a remote-control listener the
         BlackBox (a connected device) drives over Tailscale. connectedDevice FGS is NOT
         subject to the dataSync runtime timeout (which crashed the app on Android 14+). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE"/>
    <!-- connectedDevice FGS requires one of a set of companion perms; CHANGE_NETWORK_STATE
         is a normal (auto-granted) one and fits a network-reached listener. -->
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE"/>
    <!-- Storage permissions for downloading files -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="28"/>
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32"/>
    <!-- Overlay permission for floating bubble -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW"/>
    <!-- Alarm clock access for the set_alarm/set_timer on-device intent actions -->
    <uses-permission android:name="com.android.alarm.permission.SET_ALARM"/>

    <!-- Package-visibility (Android 11+). Decision 9 / M1.5: the frontier model must
         be able to RESOLVE and LAUNCH arbitrary installed apps + deep links via the
         intent path (and the gesture layer's open_app, which uses
         getLaunchIntentForPackage — gated by this visibility). We deliberately choose
         a BROAD-BUT-HONEST <queries> over QUERY_ALL_PACKAGES: the LAUNCHER filter
         makes every launchable app visible and the BROWSABLE http/https filters make
         every web/deep-link handler visible, which covers the need WITHOUT the
         Play-flagged sensitive QUERY_ALL_PACKAGES permission. (It also stays scoped to
         *launchable* apps rather than truly ALL packages, and the app ships
         sideload/enterprise-only, never via Play — see M8.5.) The specific scheme /
         action entries below keep resolveActivity()/queryIntentActivities() working
         for each concrete intent the IntentActuator fires. Settings intents (e.g.
         ACTION_WIFI_SETTINGS / open_settings) need no entry — they resolve to the
         always-visible system settings package. -->
    <queries>
        <!-- BROAD: see + launch any installed app, and any web/deep-link handler. -->
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.BROWSABLE" />
            <data android:scheme="https" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.BROWSABLE" />
            <data android:scheme="http" />
        </intent>

        <!-- Concrete implicit intents fired by the on-device intent actuator (IntentActuator) -->
        <intent><action android:name="android.intent.action.DIAL" /><data android:scheme="tel" /></intent>
        <intent><action android:name="android.intent.action.VIEW" /><data android:scheme="geo" /></intent>
        <intent><action android:name="android.intent.action.VIEW" /><data android:scheme="google.navigation" /></intent>
        <intent><action android:name="android.intent.action.VIEW" /><data android:scheme="https" /></intent>
        <intent><action android:name="android.intent.action.VIEW" /><data android:scheme="http" /></intent>
        <intent><action android:name="android.intent.action.VIEW" /><data android:scheme="content" /></intent>
        <intent><action android:name="android.intent.action.SENDTO" /><data android:scheme="smsto" /></intent>
        <intent><action android:name="android.intent.action.SENDTO" /><data android:scheme="mailto" /></intent>
        <intent><action android:name="android.intent.action.SEND" /><data android:mimeType="text/plain" /></intent>
        <intent><action android:name="android.intent.action.INSERT" /><data android:mimeType="vnd.android.cursor.dir/event" /></intent>
        <intent><action android:name="android.intent.action.INSERT" /><data android:mimeType="vnd.android.cursor.dir/raw_contact" /></intent>
        <intent><action android:name="android.intent.action.PICK" /></intent>
        <intent><action android:name="android.intent.action.OPEN_DOCUMENT" /><data android:mimeType="*/*" /></intent>
        <intent><action android:name="android.intent.action.GET_CONTENT" /><data android:mimeType="*/*" /></intent>
        <intent><action android:name="android.intent.action.CREATE_DOCUMENT" /><data android:mimeType="*/*" /></intent>
        <intent><action android:name="android.media.action.IMAGE_CAPTURE" /></intent>
        <intent><action android:name="android.media.action.VIDEO_CAPTURE" /></intent>
        <intent><action android:name="android.media.action.MEDIA_PLAY_FROM_SEARCH" /></intent>
        <intent><action android:name="android.intent.action.WEB_SEARCH" /></intent>
        <intent><action android:name="android.intent.action.SET_ALARM" /></intent>
        <intent><action android:name="android.intent.action.SET_TIMER" /></intent>
        <intent><action android:name="android.intent.action.SHOW_ALARMS" /></intent>
    </queries>

    <application
        android:name=".PortalApplication"
        android:allowBackup="true"
        android:largeHeap="true"
        android:label="AI BlackBox Portal"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:theme="@style/Theme.AIBlackBox"
        android:usesCleartextTraffic="true"
        android:networkSecurityConfig="@xml/network_security_config">

        <!-- LiteRT-LM GPU backend (Task 2.6a): optional native libs the on-device
             Gemma engine uses for GPU delegation. required=false so phones without
             these libraries still install (CPU backend is the safe default). -->
        <uses-native-library android:name="libOpenCL.so" android:required="false"/>
        <uses-native-library android:name="libvndksupport.so" android:required="false"/>

        <service
            android:name=".KeepAliveService"
            android:foregroundServiceType="dataSync"
            android:exported="false" />

        <service
            android:name=".BackgroundTaskService"
            android:foregroundServiceType="dataSync"
            android:exported="false" />

        <!-- Phase C: durable on-device model DOWNLOAD. Runs the multi-GB HF transfer in
             a started foreground service so leaving the Model Manager screen (which
             disposes the ViewModel scope) does NOT cancel the download; progress is
             published to DownloadProgressBus, which the ViewModel observes. dataSync
             matches the transfer nature (FOREGROUND_SERVICE_DATA_SYNC + POST_NOTIFICATIONS
             perms already declared above). -->
        <service
            android:name=".ModelDownloadService"
            android:foregroundServiceType="dataSync"
            android:exported="false" />

        <!-- Pins the on-device Gemma engine in RAM (Task R2-C) so it loads ONCE and
             stays warm/resident across ViewModel/process recycles. dataSync matches
             the other long-running foreground services. Additive + graceful: if this
             service can't start, the ChatViewModel builds + uses its own engine. -->
        <service
            android:name=".LocalModelService"
            android:foregroundServiceType="connectedDevice"
            android:exported="false" />

        <!-- Keeps terminal-session WebSockets (TerminalSessionManager) warm while the
             app is backgrounded (Phase 3, terminal-session-persistence). connectedDevice
             matches LocalModelService and dodges the dataSync 6h timeout. Started when
             the first terminal opens, stopped when the last is killed. Additive + graceful:
             if it can't start, terminals still work (just not background-warm). -->
        <service
            android:name=".TerminalForegroundService"
            android:foregroundServiceType="connectedDevice"
            android:exported="false" />

        <!-- MN.4: hosts the SINGLE inbound control-port socket model-free so the device
             can receive a server /notify push and post a REAL system notification (no
             Gemma in the path), even backgrounded/closed and (via BootReceiver) surviving
             reboot. connectedDevice matches the other FGSs + dodges the dataSync timeout. -->
        <service
            android:name=".NotificationListenerFgs"
            android:foregroundServiceType="connectedDevice"
            android:exported="false" />

        <!-- MN.5: re-arms NotificationListenerFgs after a reboot with a DIRECT start in the
             receiver's onReceive() — the exempt BOOT_COMPLETED context. connectedDevice is
             NOT in the boot-blocked FGS-type set (dataSync/camera/mediaPlayback/phoneCall/
             mediaProjection/microphone), so the start is legal; a WorkManager hand-off would
             instead FORFEIT the boot exemption (worker runs in a plain background context).
             exported=true is required to receive the system BOOT_COMPLETED broadcast. -->
        <receiver
            android:name=".BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

        <service
            android:name=".overlay.OverlayService"
            android:foregroundServiceType="mediaProjection|microphone"
            android:exported="false" />

        <!-- Consented on-device phone-control AccessibilityService (Phase 4).
             BIND_ACCESSIBILITY_SERVICE is a system-enforced bind permission —
             the android:permission attribute IS the declaration (no
             <uses-permission> needed). User enables it from system Accessibility
             settings; the in-app CTA deep-links there. -->
        <service
            android:name=".overlay.BlackBoxA11yService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="true"
            android:label="@string/a11y_service_label">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <activity
            android:name=".PortalActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden"
            android:theme="@style/Theme.AIBlackBox.NoBar"/>

        <activity
            android:name=".PairingActivity"
            android:exported="true"
            android:theme="@style/Theme.AIBlackBox.NoBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <activity
            android:name=".NativeMainActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.AIBlackBox.NoBar"/>

        <!-- XR Overlay Activity — transparent floating panel in Home Space (Galaxy XR) -->
        <activity
            android:name=".overlay.XrOverlayActivity"
            android:exported="false"
            android:theme="@style/Theme.AIBlackBox.XrOverlay"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden"
            android:launchMode="singleTask"
            android:taskAffinity="">
            <property
                android:name="android.window.PROPERTY_XR_ACTIVITY_START_MODE"
                android:value="XR_ACTIVITY_START_MODE_HOME_SPACE" />
        </activity>
    </application>
</manifest>
