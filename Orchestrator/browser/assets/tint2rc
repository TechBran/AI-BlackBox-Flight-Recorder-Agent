# tint2 panel for CU agent virtual desktops (production-readiness M2,
# 2026-07-23). Taskbar + clock on a dark bottom bar — enough for an agent to
# see and switch between its open windows. App LAUNCHING lives in the openbox
# right-click menu (assets/xdg/openbox/menu.xml) and pcmanfm desktop icons;
# tint2 launcher items need .desktop files at absolute paths, which do not
# survive per-box repo locations.

# ── Backgrounds ──
# Background 1: panel
rounded = 0
border_width = 0
background_color = #16161c 95
border_color = #2d2d38 100

# Background 2: active task
rounded = 4
border_width = 1
background_color = #2b3a55 100
border_color = #4a6aa8 100

# Background 3: inactive task
rounded = 4
border_width = 1
background_color = #1f1f27 80
border_color = #2d2d38 100

# ── Panel ──
panel_items = LTC
panel_size = 100% 34
panel_margin = 0 0
panel_padding = 6 2 6
panel_position = bottom center horizontal
panel_layer = top
panel_background_id = 1
wm_menu = 1
panel_dock = 0
autohide = 0

# ── Launcher ──
# One-click app buttons. Entries reference STABLE system .desktop paths
# (verified identical on dev + MS02, Ubuntu 24.04); tint2 skips missing ones,
# so a box without e.g. google-chrome just shows fewer buttons.
launcher_padding = 6 4 8
launcher_background_id = 0
launcher_icon_size = 24
launcher_icon_theme_override = 0
launcher_tooltip = 1
launcher_item_app = /usr/share/applications/pcmanfm.desktop
launcher_item_app = /usr/share/applications/debian-xterm.desktop
launcher_item_app = /usr/share/applications/chromium-browser.desktop
launcher_item_app = /usr/share/applications/google-chrome.desktop

# ── Taskbar ──
taskbar_mode = single_desktop
taskbar_padding = 2 2 4
taskbar_background_id = 0
taskbar_name = 0

# ── Tasks ──
task_text = 1
task_icon = 1
task_centered = 0
task_maximum_size = 220 30
task_padding = 6 2 4
task_font = sans 9
task_font_color = #ccccdd 100
task_active_font_color = #ffffff 100
task_background_id = 3
task_active_background_id = 2
urgent_nb_of_blink = 8

# ── Clock ──
time1_format = %H:%M
time1_font = sans bold 10
time2_format = %a %d %b
time2_font = sans 8
clock_font_color = #ccccdd 100
clock_padding = 8 0
clock_background_id = 0

# ── Mouse ──
mouse_left = toggle_iconify
mouse_middle = none
mouse_right = close
