#!/bin/bash
# BlackBox xdg-open shim — installed ONLY in the CLI Agent bridge's PATH
# (not system-wide). Bypasses GNOME's xdg-mime defaults for HTTP(S) URLs.
#
# Why this exists (Brandon 2026-05-22):
#   Antigravity `agy` (and any other CLI that calls xdg-open for OAuth)
#   delegates to whatever `xdg-mime query default x-scheme-handler/https`
#   returns. On MSO2 Ultra that default reliably drifts back to empty or
#   to a non-browser handler (gnome-text-editor), so the OAuth URL opens
#   in a text editor instead of a browser. install.sh Step 4i tries to
#   pin the default to chromium-browser, but GNOME / snap / initial-setup
#   re-clobber it. Rather than chase that, we intercept xdg-open at the
#   tmux PATH level and route HTTP(S) directly to a browser binary.
#
# Diagnostic logging (Brandon 2026-05-23): every invocation appends to
# /tmp/blackbox-xdg-open.log with argv + env + parent cmdline so we can
# verify whether the shim is reached at all. notify-send is best-effort
# for a visual "shim fired" signal; it's silent if D-Bus / session not
# reachable.

LOG=/tmp/blackbox-xdg-open.log
{
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] xdg-open-shim called"
    echo "  argv:    $*"
    echo "  PPID:    $PPID"
    ps -o cmd= -p "$PPID" 2>/dev/null | sed 's/^/  parent:  /'
    echo "  PATH:    $PATH"
    echo "  BROWSER: $BROWSER"
    echo "  DISPLAY: $DISPLAY"
} >> "$LOG" 2>&1

# Best-effort desktop notification so Brandon can SEE that the shim is
# being called. notify-send needs D-Bus + a notification daemon, both
# of which the wizard-spawned env should have. Silent on failure.
notify-send -u low "BlackBox xdg-open shim" "Opening: $1" 2>/dev/null &

url="$1"
case "$url" in
    http://*|https://*)
        for browser in chromium-browser chromium google-chrome firefox; do
            command -v "$browser" >/dev/null 2>&1 || continue
            "$browser" --version >/dev/null 2>&1 || continue
            echo "[$(date '+%Y-%m-%d %H:%M:%S')]   -> exec $browser $url" >> "$LOG"
            exec "$browser" "$url"
        done
        echo "[$(date '+%Y-%m-%d %H:%M:%S')]   -> NO BROWSER WORKED — falling through to /usr/bin/xdg-open" >> "$LOG"
        ;;
esac

echo "[$(date '+%Y-%m-%d %H:%M:%S')]   -> non-HTTP scheme, falling through to /usr/bin/xdg-open" >> "$LOG"
exec /usr/bin/xdg-open "$@"
