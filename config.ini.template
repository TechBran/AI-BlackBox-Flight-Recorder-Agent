[paths]
gm = ./GoldMaster/v7.0.txt
gm_hash = ./GoldMaster/v7.0.sha256
volume = ./Volumes/SNAPSHOT_VOLUME.txt
archive = ./Archive/
manifest = ./Manifest/manifest.json

[auto_mint]
enable = true
turns_threshold = 1
tokens_threshold = 9999999
on_yellow = ignore
on_red = ignore
debounce_ms = 3000

[checkpoint]
turns_to_compress = 26
auto_create_interval = 24
min_snapshots_required = 5

[budget]
context_tokens_max = 120000
recent_turns_tokens = 60000
reply_buffer_tokens = 60000

# === Per-customer state — populated by onboarding wizard ===
# `list` is the operator roster shown in the Portal dropdown.
# `default` is the operator selected on Portal first-load.
# Wizard's "operator" step writes to these via /onboarding/config/users.
[users]
list = Default
default = Default

[context]
recent_fossils_per_user = 5
keyword_fossils_per_user = 3
semantic_fossils_per_user = 6
semantic_threshold = 0.60
checkpoint_snapshots = 2
max_fossil_chars = 8000
include_other_operators = false
; On-device Gemma (local provider) starts LEAN: persona + tools only, NO pushed
; fossil. semantic_k=0 + checkpoint_count=0 -> /local/turn/prepare builds an
; empty fossil block; the model builds context conversationally and pulls memory
; via tools on demand. These keys are local-path-only (cloud callers unaffected).
local_semantic_k = 0
local_checkpoint_count = 0
local_injected_tools_k = 5

[snapshot]
include_model = true
show_tokens = true
show_drift = false
show_provenance = true
perspective_enable = true
perspective_lines_max = 100

[audio]
engine = auto
model = tts-1-hd
voice = onyx
format = mp3
rate = .90
pitch = 1.0
volume = 1.3
timeout_ms = 120000

# === Per-customer state — populated by onboarding wizard ===
# `default_origin` is the URL the phone-pairing QR code targets (typically
# the Tailscale https://hostname.ts.net URL once Tailscale step completes).
# `default_operator` mirrors [users].default — the operator paired devices
# bind to by default.
[pairing]
default_origin =
default_operator = Default

[models]
google_tts_synthesize = https://texttospeech.googleapis.com/v1/text:synthesize
google_tts_voices = https://texttospeech.googleapis.com/v1/voices
google_veo = veo-3.1-generate-preview

[computer_use]
# native_mode = true  -> CU drives the real desktop; false -> sandboxed Xvfb
native_mode = true
# chrome_path = /opt/google/chrome/chrome
model_default = claude-opus-4-6
gemini_model_default = gemini-2.5-computer-use-preview-10-2025
max_iterations = 100
session_timeout_s = 300

[retrieval]
# Canonical snapshot retriever (Orchestrator/retrieval.py). Operator-locked
# defaults: recency is a MILD tie-break (relevance dominates), RRF fuses the
# keyword + semantic rankings (scale-free), MMR breaks near-duplicate session
# clusters, and a low junk floor replaces the old hard 0.60 threshold.
candidate_n = 40
rrf_c = 60
recency_weight = 0.05
recency_half_life_days = 90
mmr_lambda = 0.7
junk_floor = 0.40
# M9 (WI-3): when true, the store's model-specific junk_floor from
# Orchestrator/embeddings/registry.py (nullable, noise-band calibrated via
# scripts/calibrate_threshold.py) overrides the global junk_floor above.
# Default false = per-model floors are inert (byte-identical ranking).
# Activation criterion: enable only after a representative window of
# [RETRIEVAL] debug_log lines shows zero sub-floor relevant hits for the
# active model.
registry_floor_enabled = false
# M11 (WI-4): optional cross-encoder rerank stage. When true AND [rerank]
# below has a live provider AND the one-time latency preflight passes,
# retrieve() reranks the post-recency top rerank_candidate_n by cross-encoder
# score (rank-space remap, recency re-applied, MMR unchanged — audit A9).
# false = byte-identical ranking, zero rerank code on the path. Activation
# checklist (vllm serve incantation etc.): Orchestrator/rerank.py docstring.
rerank_enabled = false
rerank_candidate_n = 40
final_k = 10
# ── Precision levers (plan 2026-07-07, validated: real-corpus precision 30%->55%,
#    noise 45%->15%, recall not hurt). keyword_mode: fused (legacy — lexical-only
#    ids RRF-injected) | dedup (agreement-only) | gated (keyword-only must clear
#    cos_floor) | off. rerank_relevance: rankspace (legacy, order-only, absolute
#    score discarded) | preserve (keep the 0-1 score AS relevance so rerank_floor
#    can DROP junk instead of only reordering). rerank_floor: absolute cross-
#    encoder-score floor (>0 = the reranker becomes a bouncer; drops sub-floor
#    results AND the un-reranked tail). output_cos_floor: reranker-ABSENT relevance
#    gate + gated-keyword gate (>0 lets a thin query return fewer than k). min_results:
#    floor-underflow guard (a valid query always returns at least this many).
#    Calibrate rerank_floor / cos_floor per (embedding model, reranker) with
#    scripts/calibrate_retrieval.py. On a DENSE corpus cosine can't separate
#    recoveries from noise (keep output_cos_floor=0, rely on the reranker); on a
#    SPARSE corpus or a reranker-ABSENT (on-device) box, set output_cos_floor>0.
#    Shipped default = the reranker-floor path (needs a live reranker; inert without
#    one). rerank_floor 0.03 is the balanced Vertex operating point (0.02 recall-safe).
keyword_mode = fused
rerank_relevance = preserve
rerank_floor = 0.03
output_cos_floor = 0.0
min_results = 1
# rerank passage source (M4): head (body head-cut) | window (the query-richest
# body window — reranker judges each snapshot's most-relevant span, not just its
# head; helps long snapshots whose relevant turn is past the head-cut). head = byte-identical.
rerank_passage_mode = head
# OPT-IN provenance logging: when true, retrieve() prints one [RETRIEVAL] line
# per final result (rrf relevance, age_days, recency_boost, final score, which
# channels surfaced it). Observability only — does NOT change ranking. Off by
# default (cheap path); flip to true to debug "why did I get these results".
debug_log = false

[rerank]
# Cross-encoder reranker provider (Orchestrator/rerank.py — M11/WI-4).
# provider: null (no reranker; the default) | vllm (POST {base_url}/score).
# All keys have code fallbacks; this whole section is optional (fresh-box
# rule, audit A13). GET /rerank/status reports the resolved state.
# To enable on a GPU box (M13: the installer provisions vllm-reranker.service
# on port 8091): set provider = vllm here + rerank_enabled = true under
# [retrieval], then restart. base_url/model below only OVERRIDE the code
# defaults (http://localhost:8091 / qwen3-reranker-0.6b — already correct for
# the installer's service).
provider = null
# base_url = http://localhost:8091
# model = qwen3-reranker-0.6b
# timeout_s = 15
# one-time first-use probe: 1 passage must score under this ceiling or rerank
# is disabled for the process lifetime (surfaced in GET /rerank/status).
# preflight_ceiling_ms = 500
# per-candidate passage budget, chars (~= the 1024-token chunk budget).
# passage_chars = 4096
