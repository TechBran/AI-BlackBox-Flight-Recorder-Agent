# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Track 3: installer/dist/ holds packaging assets we DO want committed
# (.desktop launchers, install scripts), so override the broad `dist` rule
# above. Only the .cache subdir (Tauri build artifacts) stays ignored —
# see root .gitignore line `installer/dist/.cache/`.
!dist/
dist/.cache/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
